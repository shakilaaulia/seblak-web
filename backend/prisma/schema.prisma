generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  READY
  COMPLETED
  DECLINED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Category {
  id        String    @id
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("categories")
}

model Product {
  id          String   @id
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String   @default("makanan") @map("category_id")
  name        String
  description String   @default("")
  price       Int      @default(0) @map("base_price")
  stock       Int      @default(0)
  imageUrl    String   @default("") @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  variants    ProductVariant[]
  recipeItems ProductIngredient[]
  orderItems  OrderItem[]

  @@map("products")
}

model ProductVariant {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  name      String
  price     Int      @default(0)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderItemVariants OrderItemVariant[]

  @@map("product_variants")
}

model Ingredient {
  id          String              @id
  name        String
  remaining   Int                 @default(0)
  unit        String              @default("pcs")
  minWarning  Int                 @default(5) @map("min_warning")
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  recipeItems ProductIngredient[]

  @@map("ingredients")
}

model ProductIngredient {
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String     @map("product_id")
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  ingredientId String   @map("ingredient_id")
  quantity   Int        @default(1) @map("quantity_per_unit")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@id([productId, ingredientId])
  @@map("product_ingredients")
}

model Topping {
  id         String   @id
  name       String
  price      Int      @default(0)
  remaining  Int      @default(0)
  minWarning Int      @default(5) @map("min_warning")
  unit       String   @default("porsi")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orderItemToppings OrderItemTopping[]

  @@map("toppings")
}

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique @map("order_number")
  customerName     String      @map("customer_name")
  customerWhatsapp String      @default("") @map("customer_whatsapp")
  notes            String      @default("")
  totalPrice       Int         @default(0) @map("total_price")
  status           OrderStatus @default(PENDING)
  declineReason    String?     @map("decline_reason")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  items          OrderItem[]
  payment        Payment?
  notifications  Notification[]
  stockMovements StockMovement[]

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String   @map("order_id")
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId   String?  @map("product_id")
  productName String   @default("") @map("product_name")
  quantity    Int      @default(1)
  price       Int      @default(0) @map("unit_price")
  subtotal    Int      @default(0)
  spiciness   String   @default("")
  soup        String   @default("")
  flavors     Json?
  notes       String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  toppings OrderItemTopping[]
  variants OrderItemVariant[]

  @@map("order_items")
}

model OrderItemTopping {
  id          String     @id @default(cuid())
  orderItem   OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId String     @map("order_item_id")
  topping     Topping?   @relation(fields: [toppingId], references: [id], onDelete: SetNull)
  toppingId   String?    @map("topping_id")
  toppingName String     @default("") @map("topping_name")
  price       Int        @default(0)
  quantity    Int        @default(1)
  subtotal    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("order_item_toppings")
}

model OrderItemVariant {
  id          String          @id @default(cuid())
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId String          @map("order_item_id")
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantId   String?         @map("variant_id")
  variantName String          @default("") @map("variant_name")
  price       Int             @default(0)
  quantity    Int             @default(1)
  subtotal    Int             @default(0)
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("order_item_variants")
}

model Payment {
  id            String        @id @default(cuid())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String        @unique @map("order_id")
  method        String        @default("QRIS")
  amount        Int           @default(0)
  status        PaymentStatus @default(PENDING)
  proofUrl      String        @default("") @map("proof_url") @db.Text
  proofFileName String        @default("") @map("proof_file_name")
  verifiedAt    DateTime?     @map("verified_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model RestaurantSetting {
  id           String  @id @default("rest-1")
  name         String  @default("Seblak Mamah Zahwa")
  description  String  @default("")
  address      String  @default("")
  phone        String  @default("")
  logoUrl      String  @default("") @map("logo_url")
  isOpen       Boolean @default(true) @map("is_open")
  openHour     String  @default("09:00") @map("open_hour")
  closeHour    String  @default("21:00") @map("close_hour")
  qrisName     String  @default("SEBLAK MAMAH ZAHWA") @map("qris_name")
  qrisImageUrl String  @default("") @map("qris_image_url")

  @@map("restaurant_settings")
}

model Notification {
  id        String   @id @default(cuid())
  type      String   @default("INFO")
  title     String
  message   String
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String?  @map("order_id")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model StockMovement {
  id             String   @id @default(cuid())
  itemType       String   @map("item_type")
  itemId         String   @map("item_id")
  itemName       String   @default("") @map("item_name")
  order          Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId        String?  @map("order_id")
  delta          Int
  remainingAfter Int      @map("remaining_after")
  reason         String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("stock_movements")
}
